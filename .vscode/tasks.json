{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "AWS: SSO login codex-admin",
      "type": "shell",
      "command": "aws sso login --profile codex-admin",
      "problemMatcher": []
    },
    {
      "label": "AWS: SAM build",
      "type": "shell",
      "command": "sam build --template-file aws-lambda-scanner/template.yaml",
      "problemMatcher": []
    },
    {
      "label": "AWS: SAM guided deploy",
      "type": "shell",
      "command": "sam deploy --guided --template-file aws-lambda-scanner/template.yaml",
      "dependsOn": "AWS: SAM build",
      "problemMatcher": []
    },
    {
      "label": "Azure: Login",
      "type": "shell",
      "command": "az login",
      "problemMatcher": []
    },
    {
      "label": "Azure: Deploy NSG enforcer dry run",
      "type": "shell",
      "command": ".\\scripts\\deploy-azure-function-enforcer.ps1",
      "problemMatcher": []
    },
    {
      "label": "Azure: Create dummy NSGs dry run",
      "type": "shell",
      "command": ".\\scripts\\create-azure-dummy-nsgs.ps1",
      "problemMatcher": []
    },
    {
      "label": "Azure Functions: Run locally",
      "type": "shell",
      "command": "func start",
      "options": {
        "cwd": "${workspaceFolder}\\azure-function-enforcer"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "GCP: Verify active project",
      "type": "shell",
      "command": "gcloud config list && gcloud billing projects describe mc-compliance-lab-wc-202606 && gcloud services list --enabled --project mc-compliance-lab-wc-202606",
      "problemMatcher": []
    },
    {
      "label": "GCP: Deploy Cloud Run scanner dry run",
      "type": "shell",
      "command": ".\\scripts\\deploy-gcp-cloudrun-scanner.ps1 -ProjectId mc-compliance-lab-wc-202606 -Region us-east1",
      "problemMatcher": []
    },
    {
      "label": "GCP: Deploy Cloud Run scanner",
      "type": "shell",
      "command": ".\\scripts\\deploy-gcp-cloudrun-scanner.ps1 -ProjectId mc-compliance-lab-wc-202606 -Region us-east1 -Execute",
      "problemMatcher": []
    },
    {
      "label": "GCP: Query scanner logs",
      "type": "shell",
      "command": "gcloud logging read \"resource.type=cloud_run_revision AND resource.labels.service_name=gcp-compliance-scanner AND jsonPayload.message:(COMPLIANCE_SCAN OR COMPLIANCE_VIOLATION)\" --project mc-compliance-lab-wc-202606 --limit 20 --format json",
      "problemMatcher": []
    },
    {
      "label": "GCP: Generate firewall evidence dry run",
      "type": "shell",
      "command": ".\\scripts\\generate-gcp-chaos.ps1 -ProjectId mc-compliance-lab-wc-202606 -Region us-east1",
      "problemMatcher": []
    },
    {
      "label": "GCP: Generate firewall evidence",
      "type": "shell",
      "command": ".\\scripts\\generate-gcp-chaos.ps1 -ProjectId mc-compliance-lab-wc-202606 -Region us-east1 -Execute",
      "problemMatcher": []
    },
    {
      "label": "GCP: Generate storage IAM evidence dry run",
      "type": "shell",
      "command": ".\\scripts\\generate-gcp-storage-chaos.ps1 -ProjectId mc-compliance-lab-wc-202606 -Location us-east1",
      "problemMatcher": []
    },
    {
      "label": "GCP: Generate storage IAM evidence",
      "type": "shell",
      "command": ".\\scripts\\generate-gcp-storage-chaos.ps1 -ProjectId mc-compliance-lab-wc-202606 -Location us-east1 -Execute",
      "problemMatcher": []
    },
    {
      "label": "Git: Status",
      "type": "shell",
      "command": "git status --short --branch",
      "problemMatcher": []
    },
    {
      "type": "func",
      "label": "func: host start",
      "command": "host start",
      "problemMatcher": "$func-powershell-watch",
      "isBackground": true,
      "options": {
        "cwd": "${workspaceFolder}/azure-function-enforcer"
      }
    }
  ]
}
